{
  "name": "medicine-reminder-workers",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dev": "wrangler deploy --env dev",
    "types": "wrangler types",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply medicine-reminder-db --local",
    "db:migrate:dev": "wrangler d1 migrations apply medicine-reminder-db-dev --env dev --remote",
    "db:migrate:remote": "wrangler d1 migrations apply medicine-reminder-db --remote"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.0",
    "hono": "^4.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240222.0",
    "drizzle-kit": "^0.28.0",
    "typescript": "^5.4.2",
    "vitest": "^1.6.1",
    "wrangler": "^3.32.0"
  }
}
